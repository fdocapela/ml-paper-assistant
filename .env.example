# Get your free key at https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# Application
APP_ENV=development
LOG_LEVEL=INFO

# ChromaDB — do not change, matches docker-compose.yml
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=ml_papers

# SQLite — do not change, matches docker-compose.yml volume
SQLITE_DB_PATH=/data/threads.db

# RAG settings
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=6

# LLM settings
GEMINI_MODEL=gemini-3.1-flash-lite
EMBEDDING_MODEL=gemini-embedding-001
MAX_THREAD_HISTORY=10
